# Скопируй в .env и заполни своими значениями.
TELEGRAM_BOT_TOKEN=123456789:AA...      # токен от @BotFather
TELEGRAM_CHAT_ID=000000000              # твой chat id (число)

# CLAUDE_BIN=/full/path/to/claude       # результат `which claude`
# CLAUDE_MODEL=sonnet
# HN_MIN_POINTS=20
# HN_LOOKBACK_HOURS=36
# ENRICH_TOP_N=25                       # сколько top-историй обогащать мета-контекстом (0 = выкл)

# Гард окна запуска (для launchd --scheduled): поздний прогон пропускается.
# SCHEDULE_HOUR=9
# SCHEDULE_MINUTE=0
# RUN_WINDOW_MINUTES=90                  # шлём, только если запуск не позже 9:00 + 90 мин

# ── Бот + БД (Neon Postgres) ─────────────────────────────────────────────
# Pooled connection string из Neon (получить: `neonctl connection-string --pooled`).
# Хранить можно в libpq-форме postgresql://...  — движок сам приведёт к asyncpg.
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require
# Кто имеет доступ к боту — CSV из Telegram user_id (узнать свой: @userinfobot).
BOT_ALLOWED_USER_IDS=111111111,222222222
# Только для прод-деплоя на FastAPI Cloud (webhook). Локально (polling) не нужны.
# WEBHOOK_BASE_URL=https://ourapp.fastapicloud.dev
# WEBHOOK_SECRET=любая-длинная-случайная-строка

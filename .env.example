# Скопируй в .env и заполни своими значениями.
TELEGRAM_BOT_TOKEN=123456789:AA...      # токен от @BotFather
TELEGRAM_CHAT_ID=000000000              # твой chat id (число)

# CLAUDE_BIN=/full/path/to/claude       # результат `which claude`
# CLAUDE_MODEL=sonnet
# HN_MIN_POINTS=20
# HN_LOOKBACK_HOURS=36
# ENRICH_TOP_N=25                       # сколько top-историй обогащать мета-контекстом (0 = выкл)

# Гард окна запуска (для launchd --scheduled): поздний прогон пропускается.
# SCHEDULE_HOUR=9
# SCHEDULE_MINUTE=0
# RUN_WINDOW_MINUTES=90                  # шлём, только если запуск не позже 9:00 + 90 мин
